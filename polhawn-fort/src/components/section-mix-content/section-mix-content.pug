include ../read-more/read-more
include ../slider-mix-content/slider-mix-content

mixin section-mix-content(title)
    section.section-mix-content(class!=attributes.class)
        .container.uk-position-relative
            if (title)
                .section-mix-content__title(data-uk-scrollspy="cls: slideInLeft animated slow; repeat: false;")
                    h2 #{title}
            .section-mix-content__media
                img.section-mix-content__line(src="img/color-line-green.png" srcset="img/color-line-green.png, img/color-line-green@2x.png 2x" alt="decoration line" width="11" height="575" data-uk-scrollspy="cls: slideInUp animated slow; repeat: false;")
                .section-mix-content__media-wrap(data-uk-scrollspy="cls: slideInUp animated slow; repeat: false;")
                    img(src="img/i-see-the-sea-media.png" alt="I see the sea media modal")
                    .section-mix-content__play-button
                        button(data-uk-toggle="target: #modal-media-video" type="button").play-button
                            span
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 151 151"><circle cx="75.5" cy="75.5" r="75.5" fill="#fff" opacity=".6"/><path d="M88.61 81L72.39 91.56A4.14 4.14 0 0166 88.09V67a4.13 4.13 0 016.39-3.46l16.22 10.54a4.14 4.14 0 010 6.92z" fill="#30b298"/></svg>
                .section-mix-content__aside
                    div(data-uk-scrollspy="cls: slideInUp animated slow; repeat: false;")
                        +slider-mix-content-awards([
                            {
                                src: "img/guides-for-brides-2019.png",
                                alt: "image description"
                            },
                            {
                                src: "img/guides-for-brides-2019.png",
                                alt: "image description"
                            },
                            {
                                src: "img/guides-for-brides-2019.png",
                                alt: "image description"
                            }
                        ],
                        "min-height: 404")
                    div(data-uk-scrollspy="cls: slideInUp animated slow; repeat: false;")
                        +slider-mix-content([
                            {
                                src: "img/mix-content-slider-bg1.png",
                                alt: "image description"
                            },
                            {
                                src: "img/mix-content-slider-bg1.png",
                                alt: "image description"
                            },
                            {
                                src: "img/mix-content-slider-bg1.png",
                                alt: "image description"
                            }
                        ],
                        "animation: push; min-height: 514")
            .section-mix-content__content
                +read-more(
                    'Imagine a home-from-home vibe (if ‘home’ happens to be a Napoleonic fort, complete with drawbridge)! There’s a set of steps leading from the Fort directly down to our very own beach where you can steal a little private time together, frolic in the waves with your wedding guests and catch some very special memories – the sea views from the beach are surreal.',
                    'Imagine a home-from-home vibe (if ‘home’ happens to be a Napoleonic fort, complete with drawbridge)! There’s a set of steps leading from the Fort directly down to our very own beach where you can steal a little private time together, frolic in the waves with your wedding guests and catch some very special memories – the sea views from the beach are surreal.'
                )

