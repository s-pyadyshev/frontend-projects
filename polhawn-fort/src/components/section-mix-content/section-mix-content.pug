mixin section-mix-content--grand-hall-ceremonies(title)
    section.section-mix-content(class!=attributes.class)
        .container.uk-position-relative
            if (title)
                .section-mix-content__title(data-uk-scrollspy="cls: slideInLeft animated slow; repeat: false;")
                    h2 #{title}
            .section-mix-content__media
                img.section-mix-content__line(src="img/color-line-light-pink.png" srcset="img/color-line-light-pink.png, img/color-line-light-pink@2x.png 2x" alt="decoration line" width="11" height="575" data-uk-scrollspy="cls: slideInUp animated slow; repeat: false;")
                .section-mix-content__media-wrap(data-uk-scrollspy="cls: slideInUp animated slow; repeat: false;")
                    img(src="img/grand-hall-ceremonies.png" alt="I see the sea media modal")
                .section-mix-content__aside
                    div(data-uk-scrollspy="cls: slideInUp animated slow; repeat: false;")
                        +slider-mix-content([
                            {
                                src: "img/grand-hall-ceremonies-aside.png",
                                alt: "image description"
                            },
                            {
                                src: "img/grand-hall-ceremonies-aside.png",
                                alt: "image description"
                            },
                            {
                                src: "img/grand-hall-ceremonies-aside.png",
                                alt: "image description"
                            }
                        ],
                        "animation: push; min-height: 514", true)
            .section-mix-content__content
                +read-more(
                    'An inside wedding can be grand and formal or small and simple. It’s up to you. There are two rooms within the Fort’s mighty walls where you can tie the knot. For maximum wow factor, there’s The Grand Napoleonic Hall which seats up to 120 guests. The Emperors Room is perfect for small and intimate weddings with up to 30 guests. Receptions can be held indoors or in a marquee on the lawn. The choice is yours.',
                    'An inside wedding can be grand and formal or small and simple. It’s up to you. There are two rooms within the Fort’s mighty walls where you can tie the knot. For maximum wow factor, there’s The Grand Napoleonic Hall which seats up to 120 guests. The Emperors Room is perfect for small and intimate weddings with up to 30 guests. Receptions can be held indoors or in a marquee on the lawn. The choice is yours.',
                    'img/grand-hall-ceremonies-read-more.png',
                    'Grand hall ceremonies image'
                )

