mixin section-advert-right(imgSrc, imgAlt, h2, h3, text)
    section
        .section-advert
            img(src=imgSrc alt=imgAlt)
            div
                .container
                    .section-detail.uk-margin-auto-left
                        div
                            h2 #{h2}
                            h3 #{h3}

                        div
                            p #{text}
                        .section-detail__link
                            a(href="#").uk-button.uk-button--brushed Tell me more